#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TAP_ROOT="$(cd "$REPO_ROOT/../homebrew-tap" && pwd)"
FORMULA="$TAP_ROOT/Formula/wrk.rb"
CHANGELOG="$REPO_ROOT/CHANGELOG.md"

usage() {
  echo "Usage: $(basename "$0") vX.Y.Z"
  exit 1
}

[ "${1:-}" = "" ] && usage
VERSION="$1"
[[ "$VERSION" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]] || { echo "Error: version must be vX.Y.Z"; exit 1; }

cd "$REPO_ROOT"

# Ensure working tree is clean (CHANGELOG aside)
DIRTY=$(git status --porcelain | grep -vE '^.. (CHANGELOG|wrk)' || true)
[ -n "$DIRTY" ] && { echo "Error: uncommitted changes present"; git status --short; exit 1; }

# Ensure [Unreleased] has content to promote
grep -q '^\#\# \[Unreleased\]' "$CHANGELOG" || { echo "Error: no [Unreleased] section found in CHANGELOG.md"; exit 1; }
UNRELEASED_CONTENT=$(awk '/^## \[Unreleased\]/{found=1; next} found && /^## \[/{exit} found{print}' "$CHANGELOG")
[ -z "$(echo "$UNRELEASED_CONTENT" | tr -d '[:space:]')" ] && { echo "Error: [Unreleased] section is empty — add changelog entries first"; exit 1; }

TODAY="$(date +%Y-%m-%d)"
BARE="${VERSION#v}"

echo "Releasing $VERSION ($TODAY)..."

# 1. Bump version in wrk script
sd 'VERSION="[0-9]+\.[0-9]+\.[0-9]+"' "VERSION=\"$BARE\"" "$REPO_ROOT/wrk"

# 2. Promote [Unreleased] → [VERSION] in CHANGELOG
# 3. Promote [Unreleased] → [VERSION] in CHANGELOG
sd '## \[Unreleased\]\n' "## [Unreleased]\n\n## [$BARE] - $TODAY\n" "$CHANGELOG"

# Update comparison links
PREV_TAG=$(git tag --sort=-version:refname | grep '^v' | head -1)
sd "\[Unreleased\]: (https://github\.com/danhorst/wrk/compare/).*\.\.\.HEAD" \
   "[Unreleased]: \${1}${VERSION}...HEAD" "$CHANGELOG"
printf '[%s]: https://github.com/danhorst/wrk/compare/%s...%s\n' \
  "$BARE" "$PREV_TAG" "$VERSION" >> "$CHANGELOG"

# 4. Commit and tag
git add wrk CHANGELOG.md
git commit -m "Release $VERSION"
git tag -a "$VERSION" -m "$VERSION"

# 5. Push
git push origin main
git push origin "$VERSION"

# 6. Fetch SHA256 (retry a few times — GitHub needs a moment to publish the tarball)
TARBALL_URL="https://github.com/danhorst/wrk/archive/refs/tags/${VERSION}.tar.gz"
echo "Fetching SHA256 for tarball..."
SHA256=""
for i in 1 2 3 4 5; do
  SHA256=$(curl -sL "$TARBALL_URL" | shasum -a 256 | cut -d' ' -f1)
  [ -n "$SHA256" ] && break
  echo "  attempt $i failed, retrying in 5s..."
  sleep 5
done
[ -z "$SHA256" ] && { echo "Error: could not fetch tarball SHA256"; exit 1; }
echo "SHA256: $SHA256"

# 7. Update formula
sd 'url "https://github\.com/danhorst/wrk/archive/refs/tags/v[0-9.]+\.tar\.gz"' \
   "url \"https://github.com/danhorst/wrk/archive/refs/tags/${VERSION}.tar.gz\"" "$FORMULA"
sd 'sha256 "[a-f0-9]+"' "sha256 \"$SHA256\"" "$FORMULA"

# 8. Commit and push formula
cd "$TAP_ROOT"
git add Formula/wrk.rb
git commit -m "Update wrk to $VERSION"
git push origin main

echo "Done. $VERSION is live."
