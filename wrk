#!/usr/bin/env bash
set -euo pipefail

VERSION="1.5.3"

PROJECT_ROOT="${WRK_PROJECT_ROOT:-$HOME/git}"
WORKTREE_ROOT="${WRK_WORKTREE_ROOT:-$HOME/.wrk/worktrees}"

show_help() {
  cat <<'EOF'
wrk — tmux session manager for git projects

Usage:
  wrk [query]            Fuzzy-select a project (query pre-fills the search)
  wrk <project> <label>  Open or create a labeled sub-project session
  wrk --list             List all worktrees and their status
  wrk --clean            Review and remove worktrees for merged branches
  wrk --version          Show version
  wrk --help             Show this help

Hotkeys (in the project picker):
  ctrl-o                 Open a branch picker for the highlighted project;
                         creates a worktree-backed session for the chosen branch
  ctrl-t                 Open a named session for the highlighted project
                         in the same directory (no worktree)
  ctrl-x                 Switch to a picker of all live wrk sessions,
                         showing ◆ attached and ◇ detached

Session indicators (project picker, branch picker, session pickers, --list):
  ◆                      Session is currently attached
  ◇                      Session exists but is detached
  (none)                 No active session

Labeled sessions are backed by a git worktree in WRK_WORKTREE_ROOT.
If a branch matching <label> exists locally or on origin, it is checked
out into the worktree. Otherwise a new branch is created from HEAD.

Each new worktree receives a unique WRK_PORT (written to its .env) and
inherits a copy of the parent project's .env at creation time. If mise
is installed, the worktree is automatically trusted so .env loads in
the shell. Without mise, WRK_PORT is set but won't auto-load.

--clean removes selected worktrees and for each one also deletes the
local git branch (if fully merged) and kills the tmux session.

Environment:
  WRK_PROJECT_ROOT   Root directory to scan for git repos (default: ~/git)
  WRK_WORKTREE_ROOT  Root directory for worktrees (default: ~/.wrk/worktrees)
EOF
}

# Sanitize a user-supplied label into a git-safe branch name (hyphens preserved).
branch_name() { printf '%s' "$1" | tr -c 'a-zA-Z0-9._-' '-'; }

# Sanitize a branch name into a tmux-safe session suffix (hyphens become underscores).
session_label() { local s="${1//[!a-zA-Z0-9]/_}"; printf '%s' "$s"; }

setup_worktree_env() {
  local project_path="$1" worktree_path="$2"

  # Copy .env from parent, stripping any existing WRK_PORT so we always assign a fresh one
  if [ ! -f "$worktree_path/.env" ] && [ -f "$project_path/.env" ]; then
    grep -v '^WRK_PORT=' "$project_path/.env" > "$worktree_path/.env"
  fi

  # Assign a unique WRK_PORT (skip if already set)
  if ! grep -q '^WRK_PORT=' "$worktree_path/.env" 2>/dev/null; then
    local used_ports=()
    while IFS= read -r p; do
      used_ports+=("$p")
    done < <(grep -h '^WRK_PORT=' "$WORKTREE_ROOT"/*/*/*/.env 2>/dev/null \
      | cut -d= -f2 || true)

    local port
    while true; do
      port=$(( RANDOM % 6001 + 3000 ))
      local taken=false
      for p in "${used_ports[@]+"${used_ports[@]}"}"; do
        [ "$p" = "$port" ] && taken=true && break
      done
      $taken && continue
      lsof -iTCP:"$port" -sTCP:LISTEN -t &>/dev/null && continue
      break
    done

    printf 'WRK_PORT=%s\n' "$port" >> "$worktree_path/.env"
  fi

  if command -v mise &>/dev/null; then
    mise trust "$worktree_path" &>/dev/null
  else
    echo "wrk: mise not found — WRK_PORT set in .env but won't auto-load" >&2
  fi
}

resolve_worktree() {
  local project_path="$1" project_rel="$2" branch="$3"
  local wt="$WORKTREE_ROOT/$project_rel/$branch"
  mkdir -p "$(dirname "$wt")"

  if [ ! -d "$wt" ]; then
    if git -C "$project_path" show-ref --verify --quiet "refs/heads/$branch"; then
      git -C "$project_path" worktree add "$wt" "$branch"
    else
      git -C "$project_path" fetch --quiet origin 2>/dev/null || true
      if git -C "$project_path" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        git -C "$project_path" worktree add --track -b "$branch" "$wt" "origin/$branch"
      else
        git -C "$project_path" worktree add -b "$branch" "$wt"
      fi
    fi
  fi

  setup_worktree_env "$project_path" "$wt"
  printf '%s' "$wt"
}

pick_branch() {
  local project_path="$1"
  local base="wrk-$(session_label "$(basename "$project_path")")"

  git -C "$project_path" fetch --quiet --prune origin 2>/dev/null || true

  local sess_info attached_sess all_sess
  sess_info=$(tmux list-sessions \
    -F '#{session_name}'$'\t''#{session_attached}' 2>/dev/null \
    | grep -E "^${base}__" || true)
  attached_sess=$(printf '%s\n' "$sess_info" | awk -F'\t' '$2>0{print $1}')
  all_sess=$(printf '%s\n' "$sess_info" | cut -f1)

  local branches
  branches=$(
    {
      printf '[new]\n'
      git -C "$project_path" branch --format='%(refname:short)' 2>/dev/null
      git -C "$project_path" branch -r --format='%(refname:short)' 2>/dev/null \
        | sed 's|^origin/||' | grep -v '^HEAD'
    } | sort -u | grep -v '^$'
  )

  local lines=() ind sname
  while IFS= read -r b; do
    if [ "$b" = '[new]' ]; then
      lines+=("$b"$'\t'"  $b")
    else
      sname="${base}__$(session_label "$b")"
      if printf '%s\n' "$attached_sess" | grep -qFx "$sname"; then
        ind='◆'
      elif printf '%s\n' "$all_sess" | grep -qFx "$sname"; then
        ind='◇'
      else
        ind=' '
      fi
      lines+=("$b"$'\t'"$ind $b")
    fi
  done <<< "$branches"

  local branch
  branch=$(printf '%s\n' "${lines[@]}" \
    | fzf --delimiter=$'\t' --with-nth=2 \
          --preview '' --prompt='Branch: ' \
          --header='[new] for new branch  ◆ attached  ◇ detached') || return 1

  branch=$(printf '%s' "$branch" | cut -f1)
  if [ "$branch" = '[new]' ]; then
    printf 'Branch name: ' >&2
    read -r branch
  fi
  printf '%s' "$branch"
}

cmd_list() {
  local found=false sess_info attached ind
  sess_info=$(tmux list-sessions \
    -F '#{session_name}'$'\t''#{session_attached}' 2>/dev/null || true)
  printf '%-42s %-30s %-8s %s\n' 'WORKTREE' 'BRANCH' 'PORT' 'STATUS'
  for wt in "$WORKTREE_ROOT"/*/*/*; do
    [ -e "$wt/.git" ] || continue
    found=true
    local rel="${wt#"$WORKTREE_ROOT"/}"
    local org_project="${rel%/*}"
    local label="${rel##*/}"
    local branch
    branch=$(git -C "$wt" branch --show-current 2>/dev/null) || branch='(detached)'
    local port
    port=$(grep '^WRK_PORT=' "$wt/.env" 2>/dev/null | cut -d= -f2 || echo '—')
    local sname="wrk-$(session_label "$(basename "$org_project")")__$(session_label "$label")"
    attached=$(printf '%s\n' "$sess_info" | awk -F'\t' -v s="$sname" '$1==s{print $2; exit}')
    if [ -z "$attached" ]; then ind=' '
    elif [ "$attached" -gt 0 ]; then ind='◆'
    else ind='◇'
    fi
    printf '%-42s %-30s %-8s %s\n' "$rel" "$branch" "$port" "$ind"
  done
  $found || echo 'No worktrees found.'
}

cmd_clean() {
  # Prune stale worktree metadata from all source repos that have a worktrees dir
  for wt_dir in "$WORKTREE_ROOT"/*/*; do
    [ -d "$wt_dir" ] || continue
    local rel="${wt_dir#"$WORKTREE_ROOT"/}"
    local source="$PROJECT_ROOT/$rel"
    [ -d "$source/.git" ] && git -C "$source" worktree prune 2>/dev/null || true
  done

  local merged=() unmerged=()

  for wt in "$WORKTREE_ROOT"/*/*/*; do
    [ -e "$wt/.git" ] || continue
    local branch
    branch=$(git -C "$wt" branch --show-current 2>/dev/null) || continue
    [ -z "$branch" ] && continue

    local rel="${wt#"$WORKTREE_ROOT"/}"
    local org_project="${rel%/*}"
    local source="$PROJECT_ROOT/$org_project"
    [ -d "$source/.git" ] || continue

    local base
    base=$(git -C "$source" symbolic-ref --short HEAD 2>/dev/null) || base='main'
    git -C "$source" fetch --quiet origin "$base" 2>/dev/null || true

    if git -C "$source" branch --merged "origin/$base" 2>/dev/null \
        | grep -qE "^[[:space:]]*${branch}$"; then
      merged+=("$rel")
    else
      unmerged+=("$rel")
    fi
  done

  if [ "${#merged[@]}" -eq 0 ] && [ "${#unmerged[@]}" -eq 0 ]; then
    echo 'No worktrees found.'
    return
  fi

  local to_remove=()
  local clean_sess_info
  clean_sess_info=$(tmux list-sessions \
    -F '#{session_name}'$'\t''#{session_attached}' 2>/dev/null || true)

  _clean_lines() {
    local rel org_project label sname att ind
    for rel in "$@"; do
      org_project="${rel%/*}"
      label="${rel##*/}"
      sname="wrk-$(session_label "$(basename "$org_project")")__$(session_label "$label")"
      att=$(printf '%s\n' "$clean_sess_info" | awk -F'\t' -v s="$sname" '$1==s{print $2; exit}')
      if [ -z "$att" ]; then ind=' '
      elif [ "$att" -gt 0 ]; then ind='◆'
      else ind='◇'
      fi
      printf '%s\t%s %s\n' "$rel" "$ind" "$rel"
    done
  }

  if [ "${#merged[@]}" -gt 0 ]; then
    local selected
    selected=$(_clean_lines "${merged[@]}" \
      | fzf --delimiter=$'\t' --with-nth=2 \
            --preview "tree -C -L 1 $WORKTREE_ROOT/{1}" \
            --multi --bind 'load:select-all' \
            --prompt='Remove merged worktrees? ' \
            --header='TAB to deselect, ENTER to confirm  ◆ attached  ◇ detached' || true)
    while IFS= read -r line; do
      [ -n "$line" ] && to_remove+=("$(printf '%s' "$line" | cut -f1)")
    done <<< "$selected"
  fi

  if [ "${#unmerged[@]}" -gt 0 ]; then
    local extra
    extra=$(_clean_lines "${unmerged[@]}" \
      | fzf --delimiter=$'\t' --with-nth=2 \
            --preview "tree -C -L 1 $WORKTREE_ROOT/{1}" \
            --multi \
            --prompt='Also remove unmerged worktrees? ' \
            --header='TAB to select, ENTER to skip  ◆ attached  ◇ detached' || true)
    while IFS= read -r line; do
      [ -n "$line" ] && to_remove+=("$(printf '%s' "$line" | cut -f1)")
    done <<< "$extra"
  fi

  for rel in "${to_remove[@]+"${to_remove[@]}"}"; do
    local wt="$WORKTREE_ROOT/$rel"
    local org_project="${rel%/*}"
    local label="${rel##*/}"
    local source="$PROJECT_ROOT/$org_project"
    local branch
    branch=$(git -C "$wt" branch --show-current 2>/dev/null) || branch=''

    git -C "$source" worktree remove "$wt" 2>/dev/null \
      || git -C "$source" worktree remove --force "$wt"

    if [ -n "$branch" ]; then
      git -C "$source" branch -d "$branch" 2>/dev/null \
        || echo "Note: branch '$branch' not deleted (may have unmerged commits)"
    fi

    local sname="wrk-$(session_label "$(basename "$org_project")")__$(session_label "$label")"
    tmux kill-session -t "$sname" 2>/dev/null || true

    echo "Removed: $rel"
  done
}

# Handle subcommands before project discovery
case "${1:-}" in
  --help)    show_help; exit 0 ;;
  --version) echo "wrk $VERSION"; exit 0 ;;
  --list)    cmd_list;  exit 0 ;;
  --clean)   cmd_clean; exit 0 ;;
esac

# --- Project discovery ---

PROJECTS=()
for gitdir in "$PROJECT_ROOT"/*/*/.git; do
  [ -d "$gitdir" ] || continue
  PROJECTS+=( "${gitdir%/.git}" )
done

[ "${#PROJECTS[@]}" -eq 0 ] && exit 0

# ◆ = session attached, ◇ = session detached, ' ' = no session
_sess_all=() _sess_attached=()
while IFS=$'\t' read -r _sn _sa; do
  [[ "$_sn" == wrk-* ]] || continue
  _sess_all+=("$_sn")
  [[ "${_sa:-0}" -gt 0 ]] && _sess_attached+=("$_sn")
done < <(tmux list-sessions -F '#{session_name}'$'\t''#{session_attached}' 2>/dev/null || true)

_sess_match() {
  local base="$1" s; shift
  for s in "$@"; do [[ "$s" == "$base" || "$s" == "${base}__"* ]] && return 0; done
  return 1
}

_project_lines=()
for _p in "${PROJECTS[@]}"; do
  _rel="${_p#"$PROJECT_ROOT"/}"
  _base="wrk-$(session_label "${_p##*/}")"
  if _sess_match "$_base" "${_sess_attached[@]+"${_sess_attached[@]}"}"; then
    _ind='◆'
  elif _sess_match "$_base" "${_sess_all[@]+"${_sess_all[@]}"}"; then
    _ind='◇'
  else
    _ind=' '
  fi
  _project_lines+=("$_rel"$'\t'"$_ind $_rel")
done

_fzf_result=$(printf '%s\n' "${_project_lines[@]}" \
  | fzf --delimiter=$'\t' --with-nth=2 \
        --preview "tree -C -L 1 $PROJECT_ROOT/{1}" \
        --prompt='What do you want to work on? ' --query "${1:-}" \
        --expect=ctrl-o,ctrl-t,ctrl-x \
        --header='<C-o>: + worktree  <C-t>: + session  <C-x>: filter active')

[ -z "$_fzf_result" ] && exit 0

_fzf_key=$(printf '%s' "$_fzf_result" | head -1)
_fzf_line=$(printf '%s' "$_fzf_result" | tail -1)

if [ "$_fzf_key" = 'ctrl-x' ]; then
  _raw=$(tmux list-sessions \
    -F '#{session_name}'$'\t''#{session_attached}'$'\t''#{session_path}' 2>/dev/null \
    | grep '^wrk-' || true)
  if [ -z "$_raw" ]; then
    tmux display-message "No active wrk sessions"
    exec "$0" "$@"
  fi
  _sess=$(printf '%s' "$_raw" \
    | awk -F'\t' '{ind=($2>0)?"◆":"◇"; printf "%s\t%s %s\t%s\n", $1, ind, $1, $3}' \
    | fzf --delimiter=$'\t' --with-nth=2 \
          --preview 'tree -C -L 1 {3}' \
          --prompt='Session: ' \
          --header='enter: attach') || true
  [ -z "$_sess" ] && exit 0
  _sname=$(printf '%s' "$_sess" | cut -f1)
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$_sname"
  else
    tmux attach -d -t "$_sname"
  fi
  exit 0
fi

PROJECT_PATH=$(printf '%s' "$_fzf_line" | cut -f1)

[ -z "$PROJECT_PATH" ] && exit 0

PROJECT_REL="$PROJECT_PATH"
PROJECT_PATH="$PROJECT_ROOT/$PROJECT_PATH"

# tmux-safe base name
BASE="wrk-$(session_label "$(basename "$PROJECT_PATH")")"

# Determine session name and working directory
SESSION_DIR="$PROJECT_PATH"

if [ -n "${2:-}" ]; then
  BRANCH="$(branch_name "$2")"
  SESSION="${BASE}__$(session_label "$BRANCH")"
  SESSION_DIR="$(resolve_worktree "$PROJECT_PATH" "$PROJECT_REL" "$BRANCH")"
elif [ "$_fzf_key" = 'ctrl-o' ]; then
  raw_label=$(pick_branch "$PROJECT_PATH") || exit 0
  [ -z "$raw_label" ] && exit 0
  BRANCH="$(branch_name "$raw_label")"
  SESSION="${BASE}__$(session_label "$BRANCH")"
  SESSION_DIR="$(resolve_worktree "$PROJECT_PATH" "$PROJECT_REL" "$BRANCH")"
elif [ "$_fzf_key" = 'ctrl-t' ]; then
  printf 'Session name: ' >&2
  read -r raw_label
  [ -z "$raw_label" ] && exit 0
  SESSION="${BASE}__$(session_label "$raw_label")"
else
  # Find all existing sessions for this project (default + labeled)
  _sess_info=$(tmux list-sessions \
    -F '#{session_name}'$'\t''#{session_attached}' 2>/dev/null \
    | grep -E "^${BASE}(__.*)?$" || true)

  SESSIONS=()
  while IFS= read -r s; do
    [ -n "$s" ] && SESSIONS+=("$s")
  done < <(printf '%s\n' "$_sess_info" | cut -f1)

  if [ "${#SESSIONS[@]}" -ge 2 ]; then
    _sess_lines=()
    for _s in "${SESSIONS[@]}"; do
      _att=$(printf '%s\n' "$_sess_info" | awk -F'\t' -v n="$_s" '$1==n{print $2; exit}')
      [ "${_att:-0}" -gt 0 ] && _ind='◆' || _ind='◇'
      _sess_lines+=("$_s"$'\t'"$_ind $_s")
    done
    _sess_lines+=('[new session]'$'\t''  [new session]')
    _sess_lines+=('[new worktree]'$'\t''  [new worktree]')

    SESSION=$(printf '%s\n' "${_sess_lines[@]}" \
      | fzf --delimiter=$'\t' --with-nth=2 --preview '' --prompt='Session? ') || true
    [ -z "$SESSION" ] && exit 0
    SESSION=$(printf '%s' "$SESSION" | cut -f1)
    if [ "$SESSION" = '[new session]' ]; then
      printf 'Session name: '
      read -r raw_label
      [ -z "$raw_label" ] && exit 0
      SESSION="${BASE}__$(session_label "$raw_label")"
    elif [ "$SESSION" = '[new worktree]' ]; then
      printf 'Session name: '
      read -r raw_label
      [ -z "$raw_label" ] && exit 0
      BRANCH="$(branch_name "$raw_label")"
      SESSION="${BASE}__$(session_label "$BRANCH")"
      SESSION_DIR="$(resolve_worktree "$PROJECT_PATH" "$PROJECT_REL" "$BRANCH")"
    fi
  else
    SESSION="$BASE"
  fi
fi

if command -v mise &>/dev/null && [ "$SESSION_DIR" = "$PROJECT_PATH" ]; then
  mise trust "$SESSION_DIR" &>/dev/null
fi

# Attach or create — use switch-client when already inside tmux
tmux_attach() {
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$1"
  else
    tmux attach -d -t "$1"
  fi
}

if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux_attach "$SESSION"
else
  if [ -n "${TMUX:-}" ]; then
    tmux new-session -ds "$SESSION" -c "$SESSION_DIR"
    tmux switch-client -t "$SESSION"
  else
    tmux new-session -s "$SESSION" -c "$SESSION_DIR"
  fi
fi
